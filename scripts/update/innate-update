#!/usr/bin/env python3
"""
Innate-OS Update Manager

Usage:
    innate-update check         - Check if updates are available (latest tag)
    innate-update check --dev   - Check for updates (latest commit)
    innate-update apply         - Apply pending updates (to latest tag)
    innate-update apply --dev   - Apply updates (to latest commit)
    innate-update status        - Show current version info
    innate-update start         - Start ROS services (tmux session)
    innate-update stop          - Stop ROS services
    innate-update restart       - Restart ROS services
    innate-update view          - Attach to tmux session to view ROS nodes
    innate-update daemon        - Run as background daemon (for systemd)
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import tarfile
import tempfile
import time
import urllib.request
import urllib.error
from datetime import datetime
from pathlib import Path


# ANSI color codes
class Colors:
    RED = '\033[0;31m'
    GREEN = '\033[0;32m'
    YELLOW = '\033[1;33m'
    BLUE = '\033[0;34m'
    BOLD = '\033[1m'
    NC = '\033[0m'  # No Color


class Config:
    """Configuration loaded from environment variables."""

    def __init__(self):
        self.repo_dir = Path(os.environ.get('INNATE_OS_DIR', Path.home() / 'innate-os'))
        self.state_dir = Path(os.environ.get('INNATE_STATE_DIR', '/var/lib/innate-update'))
        self.log_dir = self.repo_dir / 'logs'
        self.update_cache = self.state_dir / 'update-cache'
        self.branch = os.environ.get('INNATE_UPDATE_BRANCH', 'main')
        self.github_repo = os.environ.get('GITHUB_REPO', 'cristidragomir97/innate-os')
        self.daemon_interval = int(os.environ.get('INNATE_UPDATE_INTERVAL', '3600'))
        self.github_token = os.environ.get('GITHUB_TOKEN', '')

        # Ensure directories exist
        self.log_dir.mkdir(parents=True, exist_ok=True)
        try:
            self.state_dir.mkdir(parents=True, exist_ok=True)
        except PermissionError:
            pass

    def load_github_token(self):
        """Load saved GitHub token for private repos."""
        if self.github_token:
            return

        token_file = self.state_dir / '.github_token'
        if token_file.exists():
            self.github_token = token_file.read_text().strip()
            os.environ['GITHUB_TOKEN'] = self.github_token


class Logger:
    """Simple logger with colors and file output."""

    def __init__(self, log_file: Path):
        self.log_file = log_file

    def _write_to_file(self, message: str):
        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        try:
            with open(self.log_file, 'a') as f:
                f.write(f'[{timestamp}] {message}\n')
        except (PermissionError, OSError):
            pass

    def info(self, message: str):
        timestamp = datetime.now().strftime('%H:%M:%S')
        print(f"{Colors.BLUE}[{timestamp}]{Colors.NC} {message}")
        self._write_to_file(message)

    def success(self, message: str):
        print(f"{Colors.GREEN}✓{Colors.NC} {message}")

    def warning(self, message: str):
        print(f"{Colors.YELLOW}⚠{Colors.NC} {message}")

    def error(self, message: str):
        print(f"{Colors.RED}[ERROR]{Colors.NC} {message}", file=sys.stderr)
        self._write_to_file(f'ERROR: {message}')


class GitHubAPI:
    """GitHub API client for fetching release information."""

    def __init__(self, config: Config):
        self.config = config
        self.base_url = f"https://api.github.com/repos/{config.github_repo}"

    def _request(self, url: str, accept: str = "application/vnd.github+json") -> bytes:
        """Make authenticated request to GitHub API."""
        headers = {"Accept": accept}
        if self.config.github_token:
            headers["Authorization"] = f"token {self.config.github_token}"

        req = urllib.request.Request(url, headers=headers)
        try:
            with urllib.request.urlopen(req, timeout=30) as response:
                return response.read()
        except urllib.error.HTTPError as e:
            raise Exception(f"GitHub API error: {e.code} {e.reason}")
        except urllib.error.URLError as e:
            raise Exception(f"Network error: {e.reason}")

    def get_latest_release(self) -> dict:
        """Get latest release info from GitHub."""
        url = f"{self.base_url}/releases/latest"
        data = self._request(url)
        return json.loads(data)

    def get_release_by_tag(self, tag: str) -> dict:
        """Get release info by tag name."""
        url = f"{self.base_url}/releases/tags/{tag}"
        data = self._request(url)
        return json.loads(data)

    def download_asset(self, asset_url: str, dest_path: Path) -> bool:
        """Download a release asset."""
        # For private repos, need to use API URL with octet-stream accept header
        headers = {"Accept": "application/octet-stream"}
        if self.config.github_token:
            headers["Authorization"] = f"token {self.config.github_token}"

        req = urllib.request.Request(asset_url, headers=headers)
        try:
            with urllib.request.urlopen(req, timeout=300) as response:
                with open(dest_path, 'wb') as f:
                    shutil.copyfileobj(response, f)
            return True
        except (urllib.error.HTTPError, urllib.error.URLError):
            return False

    def find_asset_url(self, release: dict, pattern: str = ".tar.gz") -> tuple[str, str]:
        """Find asset URL matching pattern (excluding -source.tar.gz).

        Returns (api_url, asset_name) tuple.
        """
        for asset in release.get("assets", []):
            name = asset.get("name", "")
            if name.endswith(pattern) and "-source" not in name:
                # Use API URL for downloading (works with private repos)
                return asset.get("url", ""), name
        return "", ""


class ServiceManager:
    """Manage ROS services (tmux-based)."""

    TMUX_SESSION = "ros_nodes"
    DISCOVERY_SESSION = "discovery"

    def __init__(self, config: Config, logger: Logger):
        self.config = config
        self.logger = logger
        self.launch_script = config.repo_dir / 'scripts' / 'launch_ros_in_tmux.sh'

    def _run(self, cmd: list, check: bool = True) -> subprocess.CompletedProcess:
        """Run a command."""
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        if check and result.returncode != 0:
            raise subprocess.CalledProcessError(result.returncode, cmd, result.stdout, result.stderr)
        return result

    def _tmux_session_exists(self, session: str) -> bool:
        """Check if a tmux session exists."""
        result = self._run(['tmux', 'has-session', '-t', session], check=False)
        return result.returncode == 0

    def _systemd_service_active(self, service: str) -> bool:
        """Check if a systemd service is active."""
        result = self._run(['systemctl', 'is-active', '--quiet', service], check=False)
        return result.returncode == 0

    def is_running(self) -> bool:
        """Check if ROS services are running."""
        return self._tmux_session_exists(self.TMUX_SESSION)

    def is_discovery_running(self) -> bool:
        """Check if discovery server is running."""
        if self._systemd_service_active('discovery-server.service'):
            return True
        return self._tmux_session_exists(self.DISCOVERY_SESSION)

    def start(self) -> int:
        """Start ROS services."""
        if self.is_running():
            self.logger.warning(f"ROS services already running (tmux session '{self.TMUX_SESSION}')")
            print("Use 'innate-update view' to attach to the session")
            print("Use 'innate-update restart' to restart services")
            return 0

        if not self.launch_script.exists():
            self.logger.error(f"Launch script not found: {self.launch_script}")
            return 1

        self.logger.info("Starting ROS services...")

        # Run the launch script in background
        # The script itself handles discovery server and creates tmux session
        try:
            # Start in background using nohup
            subprocess.Popen(
                ['nohup', 'bash', str(self.launch_script)],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
                cwd=str(self.config.repo_dir)
            )

            # Wait a moment for session to start
            import time
            time.sleep(2)

            if self.is_running():
                self.logger.success("ROS services started")
                print(f"  Session: {self.TMUX_SESSION}")
                print("  Use 'innate-update view' to attach")
                return 0
            else:
                self.logger.error("Failed to start ROS services")
                return 1

        except Exception as e:
            self.logger.error(f"Failed to start services: {e}")
            return 1

    def stop(self) -> int:
        """Stop ROS services."""
        stopped_something = False

        # Stop ROS tmux session
        if self._tmux_session_exists(self.TMUX_SESSION):
            self.logger.info(f"Stopping tmux session '{self.TMUX_SESSION}'...")
            self._run(['tmux', 'kill-session', '-t', self.TMUX_SESSION], check=False)
            stopped_something = True

        # Stop discovery tmux session (if not managed by systemd)
        if not self._systemd_service_active('discovery-server.service'):
            if self._tmux_session_exists(self.DISCOVERY_SESSION):
                self.logger.info(f"Stopping tmux session '{self.DISCOVERY_SESSION}'...")
                self._run(['tmux', 'kill-session', '-t', self.DISCOVERY_SESSION], check=False)
                stopped_something = True

        if stopped_something:
            self.logger.success("ROS services stopped")
        else:
            self.logger.info("No ROS services were running")

        return 0

    def restart(self) -> int:
        """Restart ROS services."""
        self.logger.info("Restarting ROS services...")
        self.stop()
        import time
        time.sleep(1)
        return self.start()

    def view(self) -> int:
        """Attach to tmux session."""
        if not self.is_running():
            self.logger.error(f"ROS services not running (no tmux session '{self.TMUX_SESSION}')")
            print("Use 'innate-update start' to start services first")
            return 1

        print(f"Attaching to tmux session '{self.TMUX_SESSION}'...")
        print("  Navigation: Ctrl+b then arrow keys to switch panes")
        print("  Detach: Ctrl+b then d")
        print()

        # Replace current process with tmux attach
        os.execvp('tmux', ['tmux', 'attach', '-t', self.TMUX_SESSION])
        return 0  # Never reached

    def status(self) -> dict:
        """Get service status."""
        return {
            'ros_running': self.is_running(),
            'discovery_running': self.is_discovery_running(),
            'discovery_systemd': self._systemd_service_active('discovery-server.service'),
        }


class GitRepo:
    """Git repository operations."""

    def __init__(self, config: Config):
        self.config = config
        self.repo_dir = config.repo_dir
        self.branch = config.branch

    def _run(self, args, check=True) -> subprocess.CompletedProcess:
        """Run a git command."""
        result = subprocess.run(
            ['git', '-C', str(self.repo_dir)] + args,
            capture_output=True, text=True, check=False
        )
        if check and result.returncode != 0:
            raise subprocess.CalledProcessError(result.returncode, args, result.stdout, result.stderr)
        return result

    def check_is_repo(self) -> bool:
        return (self.repo_dir / '.git').is_dir()

    def fetch(self, tags=True) -> bool:
        args = ['fetch', 'origin', self.branch]
        if tags:
            args.append('--tags')
        result = self._run(args, check=False)
        return result.returncode == 0

    def current_commit(self) -> str:
        result = self._run(['rev-parse', 'HEAD'], check=False)
        return result.stdout.strip() if result.returncode == 0 else 'unknown'

    def current_branch(self) -> str:
        result = self._run(['rev-parse', '--abbrev-ref', 'HEAD'], check=False)
        return result.stdout.strip() if result.returncode == 0 else 'unknown'

    def remote_url(self) -> str:
        result = self._run(['config', '--get', 'remote.origin.url'], check=False)
        return result.stdout.strip() if result.returncode == 0 else 'unknown'

    def get_latest_tag(self) -> str:
        result = self._run(['tag', '--sort=-v:refname', '--merged', f'origin/{self.branch}'], check=False)
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip().split('\n')[0]
        return ''

    def get_current_tag(self) -> str:
        result = self._run(['describe', '--tags', '--exact-match', 'HEAD'], check=False)
        return result.stdout.strip() if result.returncode == 0 else ''

    def resolve_ref(self, ref: str) -> str:
        result = self._run(['rev-parse', ref], check=False)
        return result.stdout.strip() if result.returncode == 0 else 'unknown'

    def is_ancestor(self, ancestor: str, descendant: str) -> bool:
        result = self._run(['merge-base', '--is-ancestor', ancestor, descendant], check=False)
        return result.returncode == 0

    def commits_between(self, ref1: str, ref2: str) -> int:
        result = self._run(['rev-list', f'{ref1}..{ref2}', '--count'], check=False)
        try:
            return int(result.stdout.strip()) if result.returncode == 0 else 0
        except ValueError:
            return 0

    def log_oneline(self, ref1: str, ref2: str, limit: int = None) -> list[str]:
        args = ['--no-pager', 'log', '--oneline', f'{ref1}..{ref2}']
        result = self._run(args, check=False)
        if result.returncode != 0:
            return []
        lines = result.stdout.strip().split('\n') if result.stdout.strip() else []
        if limit and len(lines) > limit:
            return lines[:limit]
        return lines

    def has_local_changes(self) -> bool:
        result = self._run(['diff-index', '--quiet', 'HEAD', '--'], check=False)
        return result.returncode != 0

    def stash(self, message: str) -> bool:
        result = self._run(['stash', 'push', '-m', message], check=False)
        return result.returncode == 0

    def checkout(self, ref: str) -> bool:
        result = self._run(['checkout', ref], check=False)
        return result.returncode == 0


class UpdateManager:
    """Main update manager."""

    def __init__(self, config: Config, logger: Logger, dev_mode: bool = False):
        self.config = config
        self.logger = logger
        self.dev_mode = dev_mode
        self.git = GitRepo(config)
        self.github = GitHubAPI(config)
        self.services = ServiceManager(config, logger)

    def _check_repo(self):
        if not self.git.check_is_repo():
            self.logger.error(f"Not a git repository: {self.config.repo_dir}")
            sys.exit(1)

    def _write_cache(self, value: str):
        try:
            self.config.update_cache.parent.mkdir(parents=True, exist_ok=True)
            self.config.update_cache.write_text(value)
        except PermissionError:
            pass

    def _read_cache(self) -> str:
        try:
            if self.config.update_cache.exists():
                return self.config.update_cache.read_text().strip()
        except PermissionError:
            pass
        return ''

    def _clear_cache(self):
        try:
            self.config.update_cache.unlink(missing_ok=True)
        except PermissionError:
            pass

    def _show_commits(self, ref1: str, ref2: str, count: int, max_show: int = 10):
        commits = self.git.log_oneline(ref1, ref2, limit=max_show)
        if count > max_show:
            print(f"Showing first {max_show} of {count} commits:")
        for commit in commits:
            print(f"  {commit}")
        if count > max_show:
            print(f"  ... and {count - max_show} more commits")

    def check(self) -> int:
        """Check for updates. Returns 0 if up-to-date, 1 if updates available."""
        self._check_repo()
        self.logger.info("Checking for updates...")

        if not self.git.fetch():
            self.logger.error("Failed to fetch from remote. Check network and git authentication.")
            return 1

        current = self.git.current_commit()

        if self.dev_mode:
            return self._check_dev_mode(current)
        else:
            return self._check_tag_mode(current)

    def _check_dev_mode(self, current: str) -> int:
        target = self.git.resolve_ref(f'origin/{self.config.branch}')
        commits_behind = self.git.commits_between('HEAD', f'origin/{self.config.branch}')

        self._write_cache(str(commits_behind))

        if commits_behind == 0:
            self.logger.success("System is up to date (dev mode)")
            print(f"Current: {current[:7]}")
            return 0

        self.logger.warning(f"Updates available (dev mode): {commits_behind} new commit(s)")
        print(f"Current: {current[:7]}")
        print(f"Latest:  {target[:7]}")
        print()
        print("Recent changes:")
        self._show_commits('HEAD', f'origin/{self.config.branch}', commits_behind)
        print()
        print("Run 'innate-update apply --dev' to install updates")
        return 1

    def _check_tag_mode(self, current: str) -> int:
        latest_tag = self.git.get_latest_tag()
        current_tag = self.git.get_current_tag()

        if not latest_tag:
            self.logger.warning(f"No tags found on {self.config.branch} branch")
            print("Use 'innate-update check --dev' to check for latest commits instead")
            return 0

        latest_tag_commit = self.git.resolve_ref(latest_tag)

        if current == latest_tag_commit:
            self._write_cache('0')
            self.logger.success("System is up to date")
            print(f"Current: {current_tag} ({current[:7]})")
            return 0

        if self.git.is_ancestor(latest_tag_commit, current):
            self._write_cache('0')
            self.logger.success("System is ahead of latest stable release")
            print(f"Current: {current[:7]} (dev)")
            print(f"Latest tag: {latest_tag} ({latest_tag_commit[:7]})")
            print()
            print("You are on a development commit ahead of the latest release.")
            print("Use 'innate-update check --dev' to check for newer dev commits.")
            return 0

        self._write_cache('1')
        commits_behind = self.git.commits_between('HEAD', latest_tag)

        self.logger.warning(f"Update available: {latest_tag}")
        print(f"Current: {current_tag or current[:7]}")
        print(f"Latest:  {latest_tag} ({latest_tag_commit[:7]})")
        print()

        if commits_behind > 0:
            print(f"Changes in {latest_tag}:")
            self._show_commits('HEAD', latest_tag, commits_behind)

        print()
        print("Run 'innate-update apply' to install updates")
        return 1

    def apply(self) -> int:
        """Apply available updates by downloading release artifacts."""
        self._check_repo()

        print()
        print("╔════════════════════════════════════════════════════════╗")
        print("║          INNATE-OS UPDATE PROCESS                      ║")
        print("╚════════════════════════════════════════════════════════╝")
        print()

        self.git.fetch()
        current = self.git.current_commit()

        if self.dev_mode:
            return self._apply_dev_mode(current)
        else:
            return self._apply_tag_mode(current)

    def _apply_dev_mode(self, current: str) -> int:
        """Apply updates to latest commit (git-based, no artifacts)."""
        target_ref = f'origin/{self.config.branch}'
        target_display = f'latest commit on {self.config.branch}'
        commits_behind = self.git.commits_between('HEAD', target_ref)

        if commits_behind == 0:
            self.logger.success("Already up to date (dev mode)")
            return 0

        self.logger.info(f"Found {commits_behind} commit(s) to apply (dev mode)")
        print()
        print("Changes to be applied:")
        self._show_commits('HEAD', target_ref, commits_behind, max_show=20)

        return self._do_git_update(target_ref, target_display, current)

    def _apply_tag_mode(self, current: str) -> int:
        """Apply updates to latest tag by downloading release artifacts."""
        latest_tag = self.git.get_latest_tag()

        if not latest_tag:
            self.logger.error(f"No tags found. Use --dev to update to latest commit.")
            return 1

        latest_tag_commit = self.git.resolve_ref(latest_tag)

        if current == latest_tag_commit:
            self.logger.success(f"Already up to date at {latest_tag}")
            return 0

        if self.git.is_ancestor(latest_tag_commit, current):
            self.logger.warning(f"You are on a dev commit ahead of {latest_tag}")
            print("Use 'innate-update apply --dev' to update to the latest dev commit.")
            return 0

        commits_behind = self.git.commits_between('HEAD', latest_tag)
        self.logger.info(f"Updating to {latest_tag} ({commits_behind} commits)")
        print()
        print(f"Changes to be applied for {latest_tag}:")
        self._show_commits('HEAD', latest_tag, commits_behind, max_show=20)

        # Try to download release artifacts
        return self._do_artifact_update(latest_tag, current)

    def _do_artifact_update(self, tag: str, old_commit: str) -> int:
        """Download and extract release artifacts."""
        print()

        # Confirm
        try:
            response = input(f"Continue with update to {tag}? [y/N] ")
        except EOFError:
            response = 'n'

        if response.lower() != 'y':
            self.logger.warning("Update cancelled")
            return 0

        # Try to fetch release artifacts from GitHub
        self.logger.info(f"Fetching release {tag} from GitHub...")

        try:
            release = self.github.get_release_by_tag(tag)
            asset_url, asset_name = self.github.find_asset_url(release)

            if not asset_url:
                self.logger.warning("No release artifacts found, falling back to git update")
                return self._do_git_update(tag, tag, old_commit, skip_confirm=True)

            self.logger.info(f"Downloading {asset_name}...")

            # Download to temp file
            with tempfile.NamedTemporaryFile(suffix='.tar.gz', delete=False) as tmp:
                tmp_path = Path(tmp.name)

            if not self.github.download_asset(asset_url, tmp_path):
                self.logger.error("Failed to download release artifact")
                tmp_path.unlink(missing_ok=True)
                return 1

            # Verify it's a valid archive
            if not tarfile.is_tarfile(tmp_path):
                self.logger.error("Downloaded file is not a valid archive")
                tmp_path.unlink(missing_ok=True)
                return 1

            self.logger.info("Extracting artifacts...")

            # Extract to temp directory
            with tempfile.TemporaryDirectory() as tmp_dir:
                with tarfile.open(tmp_path) as tar:
                    tar.extractall(tmp_dir)

                tmp_path.unlink(missing_ok=True)

                # Find the extracted directory (usually innate-os/)
                extracted_dirs = list(Path(tmp_dir).iterdir())
                if len(extracted_dirs) == 1 and extracted_dirs[0].is_dir():
                    src_dir = extracted_dirs[0]
                else:
                    src_dir = Path(tmp_dir)

                # Backup current ros2_ws build artifacts (just in case)
                backup_dir = self.config.repo_dir / '.update-backup'
                ros2_ws = self.config.repo_dir / 'ros2_ws'

                # Update files from the archive
                self.logger.info("Updating installation...")

                # Copy new files, preserving .git directory
                for item in src_dir.iterdir():
                    dest = self.config.repo_dir / item.name
                    if item.name == '.git':
                        continue  # Preserve existing .git

                    if dest.exists():
                        if dest.is_dir():
                            shutil.rmtree(dest)
                        else:
                            dest.unlink()

                    if item.is_dir():
                        shutil.copytree(item, dest)
                    else:
                        shutil.copy2(item, dest)

            # Update git to point to the new tag
            self.git.fetch(tags=True)
            self.git.checkout(tag)

            new_commit = self.git.current_commit()
            self.logger.success(f"Code updated: {old_commit[:7]} → {new_commit[:7]}")

        except Exception as e:
            self.logger.error(f"Failed to download release: {e}")
            self.logger.warning("Falling back to git update")
            return self._do_git_update(tag, tag, old_commit, skip_confirm=True)

        # Run post-update script
        return self._run_post_update()

    def _do_git_update(self, target_ref: str, target_display: str, old_commit: str, skip_confirm: bool = False) -> int:
        """Perform git-based update (for dev mode or fallback)."""
        if not skip_confirm:
            print()
            try:
                response = input(f"Continue with update to {target_display}? [y/N] ")
            except EOFError:
                response = 'n'

            if response.lower() != 'y':
                self.logger.warning("Update cancelled")
                return 0

        # Stash local changes
        self.logger.info("Checking for local changes...")
        if self.git.has_local_changes():
            self.logger.warning("Stashing local changes")
            self.git.stash(f"Auto-stash before update {int(time.time())}")

        # Checkout target
        self.logger.info(f"Updating to {target_display}...")

        if self.git.checkout(target_ref):
            new_commit = self.git.current_commit()
            self.logger.success(f"Code updated: {old_commit[:7]} → {new_commit[:7]}")
        else:
            self.logger.error("Git checkout failed. Fix conflicts and try again.")
            return 1

        return self._run_post_update()

    def _run_post_update(self) -> int:
        """Run post-update script and restart services."""
        post_update_script = self.config.repo_dir / 'scripts' / 'update' / 'post_update.sh'

        if post_update_script.exists():
            self.logger.info("Running post-update script...")
            result = subprocess.run(['sudo', str(post_update_script)], check=False)
            if result.returncode == 0:
                self.logger.success("Post-update script completed")
            else:
                self.logger.error(f"Post-update script failed. Check logs: {self.config.log_dir}/post_update.log")
                return 1
        else:
            self.logger.warning("No post-update script found, skipping")

        # Auto-start ROS services after update
        self.logger.info("Starting ROS services...")
        self.services.start()

        print()
        print("╔════════════════════════════════════════════════════════╗")
        print("║          UPDATE COMPLETED SUCCESSFULLY                 ║")
        print("╚════════════════════════════════════════════════════════╝")
        print()

        self._clear_cache()
        return 0

    def status(self) -> int:
        """Show current status."""
        self._check_repo()

        current = self.git.current_commit()
        branch = self.git.current_branch()
        remote = self.git.remote_url()
        current_tag = self.git.get_current_tag()

        print("Innate-OS Status:")
        print(f"  Directory: {self.config.repo_dir}")
        print(f"  Branch:    {branch}")
        print(f"  Commit:    {current[:7]}")
        if current_tag:
            print(f"  Tag:       {current_tag}")
        print(f"  Remote:    {remote}")
        print()

        # Service status
        svc_status = self.services.status()
        print("Services:")
        if svc_status['ros_running']:
            print(f"  {Colors.GREEN}●{Colors.NC} ROS nodes: running (tmux session 'ros_nodes')")
        else:
            print(f"  {Colors.RED}○{Colors.NC} ROS nodes: stopped")

        if svc_status['discovery_running']:
            if svc_status['discovery_systemd']:
                print(f"  {Colors.GREEN}●{Colors.NC} Discovery: running (systemd)")
            else:
                print(f"  {Colors.GREEN}●{Colors.NC} Discovery: running (tmux session 'discovery')")
        else:
            print(f"  {Colors.RED}○{Colors.NC} Discovery: stopped")
        print()

        cached = self._read_cache()
        if cached:
            try:
                updates = int(cached)
                if updates > 0:
                    self.logger.warning(f"Updates available: {updates} commit(s)")
                    print("  Run 'innate-update apply' to install")
                else:
                    self.logger.success("System up to date")
            except ValueError:
                pass
        else:
            print("  Run 'innate-update check' to check for updates")

        return 0

    def start_services(self) -> int:
        """Start ROS services."""
        return self.services.start()

    def stop_services(self) -> int:
        """Stop ROS services."""
        return self.services.stop()

    def restart_services(self) -> int:
        """Restart ROS services."""
        return self.services.restart()

    def view_services(self) -> int:
        """View ROS services in tmux."""
        return self.services.view()


    def quick_check(self) -> int:
        """Quick silent check for .zshrc integration."""
        self._check_repo()

        # Use cache if recent (less than 1 hour)
        if self.config.update_cache.exists():
            try:
                cache_mtime = self.config.update_cache.stat().st_mtime
                cache_age = time.time() - cache_mtime
                if cache_age < 3600:
                    cached = self._read_cache()
                    try:
                        return 1 if int(cached) > 0 else 0
                    except ValueError:
                        pass
            except OSError:
                pass

        # Fetch silently
        if not self.git.fetch():
            return 0

        current = self.git.current_commit()
        latest_tag = self.git.get_latest_tag()

        if not latest_tag:
            self._write_cache('0')
            return 0

        latest_tag_commit = self.git.resolve_ref(latest_tag)

        if current == latest_tag_commit:
            self._write_cache('0')
            return 0

        if self.git.is_ancestor(latest_tag_commit, current):
            self._write_cache('0')
            return 0

        self._write_cache('1')
        return 1

    def daemon(self) -> int:
        """Run as background daemon."""
        self.logger.info(f"Starting innate-update daemon (interval: {self.config.daemon_interval}s)")

        while True:
            self.logger.info("Daemon: checking for updates...")

            try:
                if self.quick_check() != 0:
                    self.logger.info("Daemon: updates available")
                else:
                    self.logger.info("Daemon: system up to date")
            except Exception as e:
                self.logger.error(f"Daemon: check failed: {e}")

            time.sleep(self.config.daemon_interval)


def main():
    parser = argparse.ArgumentParser(
        description='Innate-OS Update Manager',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Commands:
  check         Check if updates are available (latest tag)
  apply         Apply pending updates (downloads release artifacts)
  status        Show current version and service status
  start         Start ROS services (tmux session)
  stop          Stop ROS services
  restart       Restart ROS services
  view          Attach to tmux session to view ROS nodes
  daemon        Run as background daemon (for systemd)

Options:
  --dev         Use latest commit instead of latest tag (git-based update)

Configuration (environment variables):
  INNATE_OS_DIR          Installation directory (default: ~/innate-os)
  INNATE_STATE_DIR       State directory (default: /var/lib/innate-update)
  INNATE_UPDATE_BRANCH   Git branch to track (default: main)
  INNATE_UPDATE_INTERVAL Daemon check interval in seconds (default: 3600)
  GITHUB_REPO            GitHub repository (default: innate-inc/innate-os)

By default, updates download pre-built release artifacts.
Use --dev flag to update via git to the latest commit.
"""
    )

    parser.add_argument('command', nargs='?',
                        choices=['check', 'apply', 'status', 'start', 'stop', 'restart', 'view', 'daemon', 'hello', '--quick-check'],
                        help='Command to run')
    parser.add_argument('--dev', '-d', action='store_true',
                        help='Use development mode (git-based update to latest commit)')

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    config = Config()
    config.load_github_token()
    logger = Logger(config.log_dir / 'update.log')
    manager = UpdateManager(config, logger, dev_mode=args.dev)

    commands = {
        'check': manager.check,
        'apply': manager.apply,
        'status': manager.status,
        'start': manager.start_services,
        'stop': manager.stop_services,
        'restart': manager.restart_services,
        'view': manager.view_services,
        'daemon': manager.daemon,
        '--quick-check': manager.quick_check,
    }

    sys.exit(commands[args.command]())


if __name__ == '__main__':
    main()
