#!/usr/bin/env python3
"""Innate OS developer CLI.  Run ``innate --help`` for usage."""

import os
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

import re

import click


# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

INNATE_OS_ROOT = Path(os.environ.get("INNATE_OS_ROOT", Path.home() / "innate-os"))
ROS_WS = INNATE_OS_ROOT / "ros2_ws"
LAUNCH_HW = INNATE_OS_ROOT / "scripts" / "launch_ros_in_tmux.sh"
LAUNCH_SIM = INNATE_OS_ROOT / "scripts" / "launch_sim_in_tmux.zsh"
DIAGNOSTICS = INNATE_OS_ROOT / "scripts" / "diagnostics.py"

TMUX_SESSION_HW = "ros_nodes"
TMUX_SESSION_SIM = "mars"

SYSTEMD_SERVICE_HW = "ros-app.service"

LOGO = r"""  ___ _   _ _   _    _  _____ _____
 |_ _| \ | | \ | |  / \|_   _| ____|
  | ||  \| |  \| | / _ \ | | |  _|
  | || |\  | |\  |/ ___ \| | | |___
 |___|_| \_|_| \_/_/   \_\_| |_____|
                 O S"""


# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------


class C:
    """ANSI colors, disabled when not a TTY."""

    _on = sys.stdout.isatty()
    RED = "\033[0;31m" if _on else ""
    GREEN = "\033[0;32m" if _on else ""
    YELLOW = "\033[1;33m" if _on else ""
    BLUE = "\033[0;34m" if _on else ""
    CYAN = "\033[0;36m" if _on else ""
    BOLD = "\033[1m" if _on else ""
    DIM = "\033[2m" if _on else ""
    NC = "\033[0m" if _on else ""


# ---------------------------------------------------------------------------
# Environment detection
# ---------------------------------------------------------------------------


def is_sim_mode():
    if os.path.exists("/.dockerenv"):
        return True
    try:
        model = Path("/proc/device-tree/model").read_text()
        if "jetson" in model.lower():
            return False
    except (FileNotFoundError, PermissionError):
        pass
    return not LAUNCH_HW.exists()


def tmux_session():
    return TMUX_SESSION_SIM if is_sim_mode() else TMUX_SESSION_HW


def tmux_session_exists(session=None):
    session = session or tmux_session()
    r = subprocess.run(["tmux", "has-session", "-t", session], capture_output=True)
    return r.returncode == 0


def tmux_window_count(session=None):
    session = session or tmux_session()
    r = subprocess.run(["tmux", "list-windows", "-t", session], capture_output=True, text=True)
    if r.returncode != 0:
        return 0
    return len(r.stdout.strip().splitlines())


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def ok(msg):
    print(f"  {C.GREEN}✓{C.NC} {msg}")


def fail(msg):
    print(f"  {C.RED}✗{C.NC} {msg}", file=sys.stderr)


def warn(msg):
    print(f"  {C.YELLOW}!{C.NC} {msg}")


def run(cmd, **kwargs):
    """Run a command, inheriting stdio by default."""
    kwargs.setdefault("check", False)
    return subprocess.run(cmd, **kwargs)


def get_version():
    r = subprocess.run(
        ["git", "-C", str(INNATE_OS_ROOT), "describe", "--tags", "--always", "--dirty"],
        capture_output=True,
        text=True,
    )
    return r.stdout.strip() if r.returncode == 0 else "unknown"


def get_mode_label():
    if is_sim_mode():
        return "simulation (Docker)"
    try:
        model = Path("/proc/device-tree/model").read_text().strip().rstrip("\x00")
        return f"hardware ({model})"
    except (FileNotFoundError, PermissionError):
        return "hardware"


def systemd_active(service):
    """Check if a systemd service unit is active."""
    r = subprocess.run(["systemctl", "is-active", "--quiet", service], capture_output=True)
    return r.returncode == 0


def zenoh_active():
    return systemd_active("zenoh-router.service")


# ---------------------------------------------------------------------------
# Service implementation
# ---------------------------------------------------------------------------


def _show_status():
    print()
    for line in LOGO.splitlines():
        print(f"  {C.CYAN}{line}{C.NC}")
    print()

    version = get_version()
    mode = get_mode_label()

    if is_sim_mode():
        session = TMUX_SESSION_SIM
        running = tmux_session_exists(session)
        if running:
            wins = tmux_window_count(session)
            ros_status = f"{C.GREEN}running{C.NC} ({wins} tmux windows)"
        else:
            ros_status = f"{C.DIM}stopped{C.NC}"
        dds_status = f"{C.DIM}n/a (sim){C.NC}"
    else:
        running = systemd_active(SYSTEMD_SERVICE_HW)
        if running:
            wins = tmux_window_count(TMUX_SESSION_HW)
            detail = f", {wins} windows" if wins else ""
            ros_status = f"{C.GREEN}running{C.NC} (systemd{detail})"
        else:
            ros_status = f"{C.DIM}stopped{C.NC}"
        if zenoh_active():
            dds_status = f"{C.GREEN}zenoh active{C.NC}"
        else:
            dds_status = f"{C.DIM}zenoh inactive{C.NC}"

    print(f"  {C.BOLD}Version:{C.NC}  {version}")
    print(f"  {C.BOLD}Mode:{C.NC}     {mode}")
    print(f"  {C.BOLD}ROS:{C.NC}      {ros_status}")
    print(f"  {C.BOLD}DDS:{C.NC}      {dds_status}")
    print()
    print(f"  {C.BOLD}innate view{C.NC}         Attach to nodes")
    print(f"  {C.BOLD}innate restart{C.NC}      Restart nodes")
    print(f"  {C.BOLD}innate build{C.NC}        Build & restart")
    print(f"  {C.BOLD}innate update{C.NC}       Check/apply updates")
    print(f"  {C.BOLD}innate diag{C.NC}         Check hardware")
    print(f"  {C.BOLD}innate volume{C.NC}       Get/set speaker volume")
    print(f"  {C.BOLD}innate --help{C.NC}       All commands")
    print()
    return 0


def _service_start():
    if is_sim_mode():
        return _service_start_sim()

    service = SYSTEMD_SERVICE_HW
    if systemd_active(service):
        warn(f"Already running (systemd: {service})")
        return 0

    r = run(["sudo", "systemctl", "start", service])
    if r.returncode != 0:
        fail(f"Failed to start {service}")
        return 1

    ok("ROS nodes starting (systemd)")
    return 0


def _service_start_sim():
    session = TMUX_SESSION_SIM
    if tmux_session_exists(session):
        warn(f"Already running (tmux session '{session}')")
        return 0

    script = LAUNCH_SIM
    if not script.exists():
        fail(f"Launch script not found: {script}")
        return 1

    subprocess.Popen(
        [str(script)],
        cwd=str(INNATE_OS_ROOT),
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    ok("ROS nodes starting (tmux)")
    return 0


def _service_stop():
    if is_sim_mode():
        session = TMUX_SESSION_SIM
        if not tmux_session_exists(session):
            warn("ROS nodes are not running")
            return 0
        run(["tmux", "kill-session", "-t", session])
        ok("ROS nodes stopped")
        return 0

    service = SYSTEMD_SERVICE_HW
    if not systemd_active(service):
        warn("ROS nodes are not running")
        return 0

    r = run(["sudo", "systemctl", "stop", service])
    if r.returncode != 0:
        fail(f"Failed to stop {service}")
        return 1

    ok("ROS nodes stopped (systemd)")
    return 0


def _service_restart():
    if is_sim_mode():
        _service_stop()
        return _service_start_sim()

    r = run(["sudo", "systemctl", "restart", SYSTEMD_SERVICE_HW])
    if r.returncode != 0:
        fail(f"Failed to restart {SYSTEMD_SERVICE_HW}")
        return 1

    ok("ROS nodes restarting (systemd)")
    return 0


def _service_view():
    session = tmux_session()
    if not tmux_session_exists(session):
        fail(f"No active session ('{session}')")
        print(f"  Use {C.BOLD}innate service start{C.NC} first")
        return 1

    try:
        os.execvp("tmux", ["tmux", "attach", "-t", session])
    except OSError as e:
        fail(f"Failed to attach to tmux: {e}")
        return 1


def _build(packages):
    ros_setup = "/opt/ros/humble/setup.bash"
    ws_setup = ROS_WS / "install" / "setup.bash"

    source_chain = f"source {ros_setup}"
    if ws_setup.exists():
        source_chain += f" && source {ws_setup}"

    colcon_cmd = "colcon build"

    if packages:
        pkg_list = " ".join(packages)
        colcon_cmd += f" --packages-select {pkg_list}"

    full_cmd = f"{source_chain} && cd {ROS_WS} && {colcon_cmd}"
    print(f"  Building{' ' + ' '.join(packages) if packages else ' workspace'}...")
    r = run(["bash", "-c", full_cmd])
    if r.returncode == 0:
        ok("Build complete")
    else:
        fail("Build failed")
    return r.returncode


def _clean():
    import shutil

    removed = []
    for d in ("build", "install", "log"):
        p = ROS_WS / d
        if p.exists():
            shutil.rmtree(p)
            removed.append(d)

    if removed:
        ok(f"Removed: {', '.join(removed)}")
    else:
        warn("Nothing to clean")
    return 0


def _get_current_volume():
    """Return current Master volume as an integer (0-100), or None on failure."""
    r = subprocess.run(
        ["amixer", "sget", "Master"],
        capture_output=True,
        text=True,
    )
    if r.returncode != 0:
        return None
    import re
    m = re.search(r"\[(\d+)%\]", r.stdout)
    return int(m.group(1)) if m else None


def _set_volume_via_ros2(level):
    """Call /set_volume ROS2 service.  Returns True on success."""
    ros_setup = "/opt/ros/humble/setup.bash"
    ws_setup = ROS_WS / "install" / "setup.bash"

    source_chain = f"source {ros_setup}"
    if ws_setup.exists():
        source_chain += f" && source {ws_setup}"

    cmd = (
        f"{source_chain} && "
        f"ros2 service call /set_volume maurice_msgs/srv/SetVolume "
        f'"{{volume_percent: {level}}}"'
    )
    r = subprocess.run(["bash", "-c", cmd], capture_output=True, text=True, timeout=15)
    return r.returncode == 0 and "success=True" in r.stdout


def _volume(level):
    if level is None:
        current = _get_current_volume()
        if current is None:
            fail("Could not read current volume (is amixer available?)")
            return 1
        print(f"  {C.BOLD}Volume:{C.NC} {current}%")
        return 0

    if not 0 <= level <= 100:
        fail("Volume must be between 0 and 100")
        return 1

    if _set_volume_via_ros2(level):
        ok(f"Volume set to {level}%")
        return 0

    fail("Failed to set volume — is the ROS2 service /set_volume running?")
    return 1


def _build_cycle(packages):
    """Stop nodes, build, restart."""
    _service_stop()
    rc = _build(packages)
    if rc != 0:
        fail("Skipping restart due to build failure")
        sys.exit(rc)
    sys.exit(_service_start())


# ---------------------------------------------------------------------------
# Update business logic
# ---------------------------------------------------------------------------


class _UpdateConfig:
    """Configuration loaded from environment variables."""

    def __init__(self):
        self.repo_dir = Path(os.environ.get("INNATE_OS_DIR", Path.home() / "innate-os"))
        self.state_dir = Path(os.environ.get("INNATE_STATE_DIR", "/var/lib/innate-update"))
        self.log_dir = self.repo_dir / "logs"
        self.update_cache = self.state_dir / "update-cache"
        self.update_lock = Path("/tmp/innate-update.lock")
        self.branch = os.environ.get("INNATE_UPDATE_BRANCH", "main")
        self.daemon_interval = int(os.environ.get("INNATE_UPDATE_INTERVAL", "3600"))

        self.log_dir.mkdir(parents=True, exist_ok=True)
        try:
            self.state_dir.mkdir(parents=True, exist_ok=True)
        except PermissionError:
            pass


class _UpdateLogger:
    """Simple logger with colors and file output."""

    def __init__(self, log_file: Path):
        self.log_file = log_file

    def _write_to_file(self, message: str):
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        try:
            with open(self.log_file, "a") as f:
                f.write(f"[{timestamp}] {message}\n")
        except (PermissionError, OSError):
            pass

    def info(self, message: str):
        timestamp = datetime.now().strftime("%H:%M:%S")
        print(f"{C.BLUE}[{timestamp}]{C.NC} {message}")
        self._write_to_file(message)

    def success(self, message: str):
        print(f"{C.GREEN}✓{C.NC} {message}")

    def warning(self, message: str):
        print(f"{C.YELLOW}⚠{C.NC} {message}")

    def error(self, message: str):
        print(f"{C.RED}[ERROR]{C.NC} {message}", file=sys.stderr)
        self._write_to_file(f"ERROR: {message}")


class _UpdateServiceManager:
    """Manage ROS services via systemd.  Used internally by _UpdateManager."""

    SYSTEMD_SERVICE = "ros-app.service"
    TMUX_SESSION = "ros_nodes"
    DISCOVERY_SESSION = "discovery"

    def __init__(self, config: _UpdateConfig, logger: _UpdateLogger):
        self.config = config
        self.logger = logger

    def _run(self, cmd: list, check: bool = True) -> subprocess.CompletedProcess:
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        if check and result.returncode != 0:
            raise subprocess.CalledProcessError(result.returncode, cmd, result.stdout, result.stderr)
        return result

    def _tmux_session_exists(self, session: str) -> bool:
        result = self._run(["tmux", "has-session", "-t", session], check=False)
        return result.returncode == 0

    def _systemd_service_active(self, service: str) -> bool:
        result = self._run(["systemctl", "is-active", "--quiet", service], check=False)
        return result.returncode == 0

    def is_running(self) -> bool:
        if self._systemd_service_active(self.SYSTEMD_SERVICE):
            return True
        return self._tmux_session_exists(self.TMUX_SESSION)

    def is_discovery_running(self) -> bool:
        if self._systemd_service_active("zenoh-router.service"):
            return True
        return self._tmux_session_exists(self.DISCOVERY_SESSION)

    def is_update_running(self) -> bool:
        """Check if an update is in progress (via lock file / live PID)."""
        if not self.config.update_lock.exists():
            return False
        try:
            content = self.config.update_lock.read_text().strip().split("\n")
            if content:
                pid = int(content[0])
                os.kill(pid, 0)
                return True
        except (ValueError, IndexError):
            return True
        except ProcessLookupError:
            self.config.update_lock.unlink(missing_ok=True)
            return False
        except PermissionError:
            return True
        return False

    def start(self) -> int:
        if self.is_running():
            self.logger.warning("ROS services already running")
            return 0

        result = self._run(["sudo", "systemctl", "start", self.SYSTEMD_SERVICE], check=False)
        if result.returncode != 0:
            self.logger.error(f"systemctl start failed: {result.stderr.strip()}")
            return 1

        self.logger.success("ROS services starting (systemd)")
        return 0

    def status(self) -> dict:
        ros_systemd = self._systemd_service_active(self.SYSTEMD_SERVICE)
        return {
            "ros_running": ros_systemd or self._tmux_session_exists(self.TMUX_SESSION),
            "ros_systemd": ros_systemd,
            "discovery_running": self.is_discovery_running(),
            "discovery_systemd": self._systemd_service_active("zenoh-router.service"),
            "update_running": self.is_update_running(),
        }


class _GitRepo:
    """Git repository operations."""

    def __init__(self, config: _UpdateConfig):
        self.config = config
        self.repo_dir = config.repo_dir
        self.branch = config.branch

    def _run(self, args, check=True) -> subprocess.CompletedProcess:
        result = subprocess.run(
            ["git", "-C", str(self.repo_dir)] + args,
            capture_output=True,
            text=True,
            check=False,
        )
        if check and result.returncode != 0:
            raise subprocess.CalledProcessError(result.returncode, args, result.stdout, result.stderr)
        return result

    def check_is_repo(self) -> bool:
        return (self.repo_dir / ".git").is_dir()

    def fetch(self, tags=True) -> bool:
        args = ["fetch", "origin", self.branch]
        if tags:
            args.extend(["--tags", "--force"])
        result = self._run(args, check=False)
        return result.returncode == 0

    def fetch_tags_only(self) -> bool:
        result = self._run(["fetch", "origin", "--tags", "--force", "--prune"], check=False)
        return result.returncode == 0

    def prune_stale_local_tags(self) -> list[str]:
        """Delete local tags that no longer exist on the remote.

        Handles the case where a bad tag was pushed then deleted — without
        pruning, users would be stuck on the stale local copy forever.
        """
        local_result = self._run(["tag", "-l"], check=False)
        if local_result.returncode != 0 or not local_result.stdout.strip():
            return []
        local_tags = set(local_result.stdout.strip().split("\n"))

        remote_result = self._run(["ls-remote", "--tags", "origin"], check=False)
        if remote_result.returncode != 0:
            return []

        remote_tags = set()
        for line in remote_result.stdout.strip().split("\n"):
            if line and "refs/tags/" in line:
                tag_ref = line.split("refs/tags/")[-1]
                tag_name = tag_ref.replace("^{}", "")
                remote_tags.add(tag_name)

        stale_tags = local_tags - remote_tags
        deleted = []
        for tag in stale_tags:
            result = self._run(["tag", "-d", tag], check=False)
            if result.returncode == 0:
                deleted.append(tag)
        return deleted

    def current_commit(self) -> str:
        result = self._run(["rev-parse", "HEAD"], check=False)
        return result.stdout.strip() if result.returncode == 0 else "unknown"

    def current_branch(self) -> str:
        result = self._run(["rev-parse", "--abbrev-ref", "HEAD"], check=False)
        return result.stdout.strip() if result.returncode == 0 else "unknown"

    def remote_url(self) -> str:
        result = self._run(["config", "--get", "remote.origin.url"], check=False)
        return result.stdout.strip() if result.returncode == 0 else "unknown"

    @staticmethod
    def is_stable_tag(tag: str) -> bool:
        """Return True for strict x.y.z tags (no suffix)."""
        return bool(re.match(r"^\d+\.\d+\.\d+$", tag))

    def get_all_tags(self) -> list[str]:
        """Get all tags merged into origin/{branch}, sorted by version descending."""
        result = self._run(
            ["tag", "--sort=-v:refname", "--merged", f"origin/{self.branch}"],
            check=False,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip().split("\n")
        return []

    def get_latest_tag(self, stable_only: bool = False) -> str:
        """Get the latest tag. If stable_only, only consider x.y.z tags."""
        tags = self.get_all_tags()
        if stable_only:
            tags = [t for t in tags if self.is_stable_tag(t)]
        return tags[0] if tags else ""

    def get_current_tag(self) -> str:
        """Get tag at HEAD. If multiple tags, prefer the stable one."""
        result = self._run(["tag", "--points-at", "HEAD"], check=False)
        if result.returncode != 0 or not result.stdout.strip():
            return ""
        tags = result.stdout.strip().split("\n")
        stable = [t for t in tags if self.is_stable_tag(t)]
        return stable[0] if stable else tags[0]

    def get_tags_newer_than(self, ref: str) -> list[str]:
        """Get all tags merged into origin/{branch} that are newer than ref.

        Deduplicates: if a stable and pre-release tag share a commit, only the stable one is kept.
        Returns tags sorted by version descending.
        """
        all_tags = self.get_all_tags()
        ref_commit = self.resolve_ref(ref)

        newer = []
        seen_commits = {}
        for tag in all_tags:
            tag_commit = self.resolve_ref(tag)
            if tag_commit == ref_commit:
                continue
            if not self.is_ancestor(ref_commit, tag_commit):
                continue
            # Dedup: prefer stable tag for a given commit
            if tag_commit in seen_commits:
                existing = seen_commits[tag_commit]
                if self.is_stable_tag(tag) and not self.is_stable_tag(existing):
                    newer = [t for t in newer if t != existing]
                    newer.append(tag)
                    seen_commits[tag_commit] = tag
            else:
                newer.append(tag)
                seen_commits[tag_commit] = tag

        return newer

    def resolve_ref(self, ref: str) -> str:
        result = self._run(["rev-parse", ref], check=False)
        return result.stdout.strip() if result.returncode == 0 else "unknown"

    def is_ancestor(self, ancestor: str, descendant: str) -> bool:
        result = self._run(["merge-base", "--is-ancestor", ancestor, descendant], check=False)
        return result.returncode == 0

    def commits_between(self, ref1: str, ref2: str) -> int:
        result = self._run(["rev-list", f"{ref1}..{ref2}", "--count"], check=False)
        try:
            return int(result.stdout.strip()) if result.returncode == 0 else 0
        except ValueError:
            return 0

    def log_oneline(self, ref1: str, ref2: str, limit: int = None) -> list[str]:
        args = ["--no-pager", "log", "--oneline", f"{ref1}..{ref2}"]
        result = self._run(args, check=False)
        if result.returncode != 0:
            return []
        lines = result.stdout.strip().split("\n") if result.stdout.strip() else []
        if limit and len(lines) > limit:
            return lines[:limit]
        return lines

    def has_local_changes(self) -> bool:
        result = self._run(["diff-index", "--quiet", "HEAD", "--"], check=False)
        return result.returncode != 0

    def stash(self, message: str) -> bool:
        result = self._run(["stash", "push", "-m", message], check=False)
        return result.returncode == 0

    def checkout(self, ref: str) -> bool:
        result = self._run(["checkout", ref], check=False)
        return result.returncode == 0

    def checkout_branch(self, branch: str, start_point: str) -> bool:
        """Checkout a local branch, resetting it to a start point."""
        result = self._run(["checkout", "-B", branch, start_point], check=False)
        return result.returncode == 0


class _UpdateManager:
    """Core update logic: check, apply, status, daemon."""

    def __init__(self, config: _UpdateConfig, logger: _UpdateLogger, dev_mode: bool = False, yes: bool = False, target: str = None):
        self.config = config
        self.logger = logger
        self.dev_mode = dev_mode
        self.yes = yes
        self.target = target
        self.git = _GitRepo(config)
        self.services = _UpdateServiceManager(config, logger)

    # -- helpers --------------------------------------------------------------

    def _check_repo(self):
        if not self.git.check_is_repo():
            self.logger.error(f"Not a git repository: {self.config.repo_dir}")
            sys.exit(1)

    def _write_cache(self, value: str):
        try:
            self.config.update_cache.parent.mkdir(parents=True, exist_ok=True)
            self.config.update_cache.write_text(value)
        except PermissionError:
            pass

    def _read_cache(self) -> str:
        try:
            if self.config.update_cache.exists():
                return self.config.update_cache.read_text().strip()
        except PermissionError:
            pass
        return ""

    def _clear_cache(self):
        try:
            self.config.update_cache.unlink(missing_ok=True)
        except PermissionError:
            pass

    def _show_commits(self, ref1: str, ref2: str, count: int, max_show: int = 10):
        commits = self.git.log_oneline(ref1, ref2, limit=max_show)
        if count > max_show:
            print(f"Showing first {max_show} of {count} commits:")
        for commit in commits:
            print(f"  {commit}")
        if count > max_show:
            print(f"  ... and {count - max_show} more commits")

    def _create_update_lock(self):
        try:
            self.config.update_lock.parent.mkdir(parents=True, exist_ok=True)
            self.config.update_lock.write_text(f"{os.getpid()}\n{datetime.now().isoformat()}\n")
        except Exception:
            pass

    def _remove_update_lock(self):
        try:
            self.config.update_lock.unlink(missing_ok=True)
        except Exception:
            pass

    # -- check ----------------------------------------------------------------

    def check(self) -> int:
        """Check for updates.  Returns 0 if up-to-date, 1 if updates available."""
        self._check_repo()
        self.logger.info("Checking for updates...")

        if not self.git.fetch():
            self.logger.error("Failed to fetch from remote. Check network and git authentication.")
            return 1

        deleted_tags = self.git.prune_stale_local_tags()
        if deleted_tags:
            self.logger.info(f"Pruned stale local tags: {', '.join(deleted_tags)}")

        current = self.git.current_commit()
        if self.dev_mode:
            return self._check_dev_mode(current)
        return self._check_tag_mode(current)

    def _check_dev_mode(self, current: str) -> int:
        current_tag = self.git.get_current_tag()
        newer_tags = self.git.get_tags_newer_than("HEAD")
        on_main = self.git.current_branch() == self.config.branch
        commits_behind = self.git.commits_between(
            "HEAD", f"origin/{self.config.branch}"
        ) if on_main else 0

        if not newer_tags and commits_behind == 0:
            self.logger.success("System is up to date (dev)")
            print(f"Current: {current_tag or current[:7]}")
            return 0

        print(f"Current: {current_tag or current[:7]}")
        print()

        if newer_tags:
            self.logger.warning(f"{len(newer_tags)} newer tag(s) available:")
            for tag in newer_tags:
                tag_commit = self.git.resolve_ref(tag)
                stable = "" if self.git.is_stable_tag(tag) else " (pre-release)"
                print(f"  {tag} ({tag_commit[:7]}){stable}")
            print()

        if commits_behind > 0:
            remote_tip = self.git.resolve_ref(f"origin/{self.config.branch}")
            print(f"{commits_behind} commit(s) ahead on {self.config.branch} ({remote_tip[:7]})")
            print()

        hint = "Run 'innate update --dev apply <tag>'"
        if on_main:
            hint += f" or 'innate update --dev apply {self.config.branch}'"
        print(hint)
        return 1

    def _check_tag_mode(self, current: str) -> int:
        latest_tag = self.git.get_latest_tag(stable_only=True)
        current_tag = self.git.get_current_tag()

        if not latest_tag:
            self.logger.warning(f"No tags found on {self.config.branch} branch")
            print("Use 'innate update --dev check' to check for latest commits instead")
            return 0

        latest_tag_commit = self.git.resolve_ref(latest_tag)

        if current == latest_tag_commit:
            self._write_cache("0")
            self.logger.success("System is up to date")
            print(f"Current: {current_tag} ({current[:7]})")
            return 0

        if self.git.is_ancestor(latest_tag_commit, current):
            self._write_cache("0")
            self.logger.success("System is ahead of latest stable release")
            print(f"Current: {current[:7]} (dev)")
            print(f"Latest tag: {latest_tag} ({latest_tag_commit[:7]})")
            print()
            print("You are on a development commit ahead of the latest release.")
            print("Use 'innate update --dev check' to check for newer dev commits.")
            return 0

        self._write_cache("1")
        commits_behind = self.git.commits_between("HEAD", latest_tag)
        self.logger.warning(f"Update available: {latest_tag}")
        print(f"Current: {current_tag or current[:7]}")
        print(f"Latest:  {latest_tag} ({latest_tag_commit[:7]})")
        print()
        if commits_behind > 0:
            print(f"Changes in {latest_tag}:")
            self._show_commits("HEAD", latest_tag, commits_behind)
        print()
        print("Run 'innate update apply' to install updates")
        return 1

    # -- apply ----------------------------------------------------------------

    def apply(self) -> int:
        """Apply available updates."""
        self._check_repo()

        # For dev mode without target, fail fast before banner/fetch
        if self.dev_mode and not self.target:
            self.git.fetch()
            newer_tags = self.git.get_tags_newer_than("HEAD")
            self.logger.error("No target specified. Usage: innate update --dev apply <target>")
            print()
            if newer_tags:
                print("Available tags:")
                for tag in newer_tags:
                    stable = "" if self.git.is_stable_tag(tag) else " (pre-release)"
                    print(f"  {tag}{stable}")
                print()
            print("Examples:")
            print("  innate update --dev apply 0.5.0-rc1")
            if self.git.current_branch() == self.config.branch:
                print(f"  innate update --dev apply {self.config.branch}")
            return 1

        self._create_update_lock()

        print()
        print("╔════════════════════════════════════════════════════════╗")
        print("║          INNATE-OS UPDATE PROCESS                      ║")
        print("╚════════════════════════════════════════════════════════╝")
        print()

        self.git.fetch()
        current = self.git.current_commit()

        if self.dev_mode or self.target:
            return self._apply_dev_mode(current)
        return self._apply_tag_mode(current)

    def _apply_dev_mode(self, current: str) -> int:
        """Apply updates to a specific target (tag or branch)."""
        target = self.target

        # If target is the branch name, track remote branch
        if target == self.config.branch:
            remote_ref = f"origin/{self.config.branch}"
            commits_behind = self.git.commits_between("HEAD", remote_ref)
            if commits_behind == 0:
                self.logger.success(f"Already up to date with {self.config.branch}")
                self._remove_update_lock()
                return 0

            self.logger.info(f"Updating to latest on {self.config.branch} ({commits_behind} commits)")
            print()
            print("Changes to be applied:")
            self._show_commits("HEAD", remote_ref, commits_behind, max_show=20)

            return self._do_git_update(
                self.config.branch, f"latest on {self.config.branch}", current,
                track_remote=remote_ref,
            )

        # Target is a tag — verify it exists
        tag_commit = self.git.resolve_ref(target)
        if tag_commit == "unknown":
            self.logger.error(f"Unknown target: {target}")
            self._remove_update_lock()
            return 1

        if tag_commit == current:
            self.logger.success(f"Already at {target}")
            self._remove_update_lock()
            return 0

        commits = self.git.commits_between("HEAD", target)
        self.logger.info(f"Updating to {target} ({commits} commits)")
        if commits > 0:
            print()
            print(f"Changes to be applied for {target}:")
            self._show_commits("HEAD", target, commits, max_show=20)

        return self._do_git_update(target, target, current)

    def _apply_tag_mode(self, current: str) -> int:
        latest_tag = self.git.get_latest_tag(stable_only=True)

        if not latest_tag:
            self.logger.error("No tags found. Use --dev to update to latest commit.")
            self._remove_update_lock()
            return 1

        latest_tag_commit = self.git.resolve_ref(latest_tag)

        if current == latest_tag_commit:
            self.logger.success(f"Already up to date at {latest_tag}")
            self._remove_update_lock()
            return 0

        if self.git.is_ancestor(latest_tag_commit, current):
            self.logger.warning(f"You are on a dev commit ahead of {latest_tag}")
            print("Use 'innate update --dev apply' to update to the latest dev commit.")
            self._remove_update_lock()
            return 0

        commits_behind = self.git.commits_between("HEAD", latest_tag)
        self.logger.info(f"Updating to {latest_tag} ({commits_behind} commits)")
        print()
        print(f"Changes to be applied for {latest_tag}:")
        self._show_commits("HEAD", latest_tag, commits_behind, max_show=20)

        return self._do_git_update(latest_tag, latest_tag, current)

    def _do_git_update(self, target_ref, target_display, old_commit, skip_confirm=False, track_remote=None):
        if not skip_confirm and not self.yes:
            print()
            try:
                response = input(f"Continue with update to {target_display}? [y/N] ")
            except EOFError:
                response = "n"
            if response.lower() != "y":
                self.logger.warning("Update cancelled")
                return 0

        self.logger.info("Checking for local changes...")
        if self.git.has_local_changes():
            self.logger.warning("Stashing local changes")
            self.git.stash(f"Auto-stash before update {int(time.time())}")

        self.logger.info(f"Updating to {target_display}...")
        if track_remote is not None:
            success = self.git.checkout_branch(target_ref, track_remote)
        else:
            success = self.git.checkout(target_ref)

        if success:
            new_commit = self.git.current_commit()
            self.logger.success(f"Code updated: {old_commit[:7]} → {new_commit[:7]}")
        else:
            self.logger.error("Git checkout failed. Fix conflicts and try again.")
            self._remove_update_lock()
            return 1

        return self._run_post_update()

    def _run_post_update(self) -> int:
        post_update_script = self.config.repo_dir / "scripts" / "update" / "post_update.sh"

        if post_update_script.exists():
            self.logger.info("Running post-update script...")
            result = subprocess.run(["sudo", str(post_update_script)], check=False)
            if result.returncode == 0:
                self.logger.success("Post-update script completed")
            else:
                self.logger.error(
                    f"Post-update script failed. Check logs: {self.config.log_dir}/post_update.log"
                )
                self._remove_update_lock()
                return 1
        else:
            self.logger.warning("No post-update script found, skipping")

        self.logger.info("Starting ROS services...")
        self.services.start()

        print()
        print("╔════════════════════════════════════════════════════════╗")
        print("║          UPDATE COMPLETED SUCCESSFULLY                 ║")
        print("╚════════════════════════════════════════════════════════╝")
        print()

        self._clear_cache()
        self._remove_update_lock()
        return 0

    # -- status ---------------------------------------------------------------

    def status(self) -> int:
        self._check_repo()

        current = self.git.current_commit()
        branch = self.git.current_branch()
        remote = self.git.remote_url()
        current_tag = self.git.get_current_tag()

        print("Innate-OS Status:")
        print(f"  Directory: {self.config.repo_dir}")
        print(f"  Branch:    {branch}")
        print(f"  Commit:    {current[:7]}")
        if current_tag:
            print(f"  Tag:       {current_tag}")
        print(f"  Remote:    {remote}")
        print()

        svc_status = self.services.status()
        print("Services:")
        if svc_status["ros_running"]:
            if svc_status.get("ros_systemd"):
                print(f"  {C.GREEN}●{C.NC} ROS nodes: running (systemd)")
            else:
                print(f"  {C.GREEN}●{C.NC} ROS nodes: running (tmux session 'ros_nodes')")
        else:
            print(f"  {C.RED}○{C.NC} ROS nodes: stopped")

        if svc_status["discovery_running"]:
            if svc_status["discovery_systemd"]:
                print(f"  {C.GREEN}●{C.NC} Zenoh: running (systemd)")
            else:
                print(f"  {C.GREEN}●{C.NC} Zenoh: running (tmux session 'discovery')")
        else:
            print(f"  {C.RED}○{C.NC} Zenoh: stopped")

        if svc_status["update_running"]:
            print(f"  {C.YELLOW}●{C.NC} Update: in progress (lock: {self.config.update_lock})")
        print()

        cached = self._read_cache()
        if cached:
            try:
                updates = int(cached)
                if updates > 0:
                    self.logger.warning(f"Updates available: {updates} commit(s)")
                    print("  Run 'innate update apply' to install")
                else:
                    self.logger.success("System up to date")
            except ValueError:
                pass
        else:
            print("  Run 'innate update check' to check for updates")

        return 0

    # -- quick-check / daemon -------------------------------------------------

    def quick_check(self) -> int:
        """Silent check for .zshrc / ssh-welcome integration."""
        if os.environ.get("SKIP_UPDATE_CHECK"):
            return 0

        self._check_repo()

        if self.config.update_cache.exists():
            try:
                cache_mtime = self.config.update_cache.stat().st_mtime
                cache_age = time.time() - cache_mtime
                if cache_age < 3600:
                    cached = self._read_cache()
                    try:
                        return 1 if int(cached) > 0 else 0
                    except ValueError:
                        pass
            except OSError:
                pass

        self.git.fetch()

        current = self.git.current_commit()
        latest_tag = self.git.get_latest_tag(stable_only=True)

        if not latest_tag:
            return 2

        latest_tag_commit = self.git.resolve_ref(latest_tag)

        if current == latest_tag_commit:
            self._write_cache("0")
            return 0

        if self.git.is_ancestor(latest_tag_commit, current):
            self._write_cache("0")
            return 0

        self._write_cache("1")
        return 1

    def daemon(self) -> int:
        self.logger.info(f"Starting innate-update daemon (interval: {self.config.daemon_interval}s)")

        self.logger.info("Daemon: fetching latest tags...")
        if self.git.fetch_tags_only():
            self.logger.info("Daemon: tags fetched successfully")
        else:
            self.logger.warning("Daemon: failed to fetch tags")

        while True:
            self.logger.info("Daemon: checking for updates...")
            try:
                if self.quick_check() != 0:
                    self.logger.info("Daemon: updates available")
                else:
                    self.logger.info("Daemon: system up to date")
            except Exception as e:
                self.logger.error(f"Daemon: check failed: {e}")
            time.sleep(self.config.daemon_interval)


def _make_update_manager(dev=False, yes=False, target=None):
    config = _UpdateConfig()
    logger = _UpdateLogger(config.log_dir / "update.log")
    return _UpdateManager(config, logger, dev_mode=dev, yes=yes, target=target)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


@click.group(invoke_without_command=True)
@click.pass_context
def cli(ctx):
    """Innate OS developer CLI.

    \b
    Shortcuts:
      innate view       → innate service view
      innate restart    → innate service restart

    Alias: in8
    """
    if ctx.invoked_subcommand is None:
        sys.exit(_show_status())


# -- service group ------------------------------------------------------------


@cli.group(invoke_without_command=True)
@click.pass_context
def service(ctx):
    """Manage ROS nodes via systemd (start/stop/restart/view)."""
    if ctx.invoked_subcommand is None:
        click.echo(ctx.get_help())
        ctx.exit(1)


@service.command("start")
def service_start():
    """Start all ROS nodes (systemd on hardware, tmux in sim)."""
    sys.exit(_service_start())


@service.command("stop")
def service_stop():
    """Stop all ROS nodes (systemd on hardware, tmux in sim)."""
    sys.exit(_service_stop())


@service.command("restart")
def service_restart():
    """Restart all ROS nodes (systemd on hardware, tmux in sim)."""
    sys.exit(_service_restart())


@service.command("view")
def service_view_cmd():
    """Attach to node tmux session."""
    sys.exit(_service_view())


# -- shortcuts ----------------------------------------------------------------


@cli.command()
def view():
    """Attach to ROS node tmux session."""
    sys.exit(_service_view())


@cli.command()
def restart():
    """Restart all ROS nodes."""
    sys.exit(_service_restart())


# -- build / clean / diag ----------------------------------------------------


@cli.command()
@click.argument("packages", nargs=-1)
def build(packages):
    """Stop nodes, build workspace, restart nodes."""
    _build_cycle(packages)


@cli.command()
def clean():
    """Remove build/install/log artifacts."""
    sys.exit(_clean())


@cli.command()
def diag():
    """Run hardware diagnostics."""
    if not DIAGNOSTICS.exists():
        fail(f"Diagnostics script not found: {DIAGNOSTICS}")
        sys.exit(1)
    try:
        os.execvp("python3", ["python3", str(DIAGNOSTICS)])
    except OSError as e:
        fail(f"Failed to launch diagnostics: {e}")
        sys.exit(1)


@cli.command()
@click.argument("level", type=click.IntRange(0, 100), required=False, metavar="[0-100]")
def volume(level):
    """Get or set the robot speaker volume.

    \b
    Examples:
      innate volume          Show current volume
      innate volume 60       Set volume to 60%
      innate volume 0        Mute
    """
    sys.exit(_volume(level))


# -- update -------------------------------------------------------------------


@cli.group("update", invoke_without_command=True)
@click.option("--dev", "-d", is_flag=True, help="Use dev mode (pre-release tags, branch targets)")
@click.pass_context
def update(ctx, dev):
    """Check and apply Innate-OS updates.

    \b
    Pass --dev before the subcommand to enable dev mode:
      innate update --dev check        List all newer tags (including pre-release)
      innate update --dev apply <tag>  Apply a specific tag or branch
    """
    ctx.ensure_object(dict)
    ctx.obj["dev"] = dev
    if ctx.invoked_subcommand is None:
        click.echo(ctx.get_help())


@update.command()
@click.pass_context
def check(ctx):
    """Check if updates are available (stable x.y.z tags by default)."""
    sys.exit(_make_update_manager(dev=ctx.obj["dev"]).check())


@update.command()
@click.option("--yes", "-y", is_flag=True, help="Skip confirmation prompts")
@click.option("--background", "-b", is_flag=True, help="Run in background tmux session")
@click.option("--in-tmux", is_flag=True, hidden=True)
@click.argument("target", required=False, default=None)
@click.pass_context
def apply(ctx, yes, background, in_tmux, target):
    """Apply pending updates.

    \b
    Examples:
      innate update apply                    Apply latest stable tag
      innate update --dev apply 0.5.0-rc1    Apply a specific tag
      innate update --dev apply main         Update to latest commit on main
      innate update apply 0.5.0              Apply a specific target
    """
    dev = ctx.obj["dev"]
    if background and not in_tmux:
        cmd = ["tmux", "new-session", "-d", "-s", "innate_update", "innate", "update"]
        if dev:
            cmd.append("--dev")
        cmd.extend(["apply", "--in-tmux"])
        if yes:
            cmd.append("--yes")
        if target:
            cmd.append(target)
        result = subprocess.run(cmd)
        if result.returncode == 0:
            print("Update started in background (tmux session 'innate_update')")
            print("  View progress: tmux attach -t innate_update")
            sys.exit(0)
        else:
            print("Failed to start background update session", file=sys.stderr)
            sys.exit(1)

    sys.exit(_make_update_manager(dev=dev, yes=yes, target=target).apply())


@update.command()
def status():
    """Show current version and service info."""
    sys.exit(_make_update_manager().status())


@update.command(hidden=True)
def daemon():
    """Run as background daemon (for systemd)."""
    sys.exit(_make_update_manager().daemon())


@update.command("reinstall")
def reinstall():
    """Re-run post-update script (systemd, sudoers, deps, rebuild)."""
    script = INNATE_OS_ROOT / "scripts" / "update" / "post_update.sh"
    if not script.exists():
        fail(f"Post-update script not found: {script}")
        sys.exit(1)
    print(f"  Running {script}...")
    r = run(["sudo", str(script)])
    sys.exit(r.returncode)


@update.command("quick-check", hidden=True)
def quick_check():
    """Silent check for shell/app integration."""
    sys.exit(_make_update_manager().quick_check())


# -- completions (auto-generated) ---------------------------------------------


def _zsh_completions():
    """Walk the Click command tree and emit a static zsh completion script."""

    def fmt_commands(group):
        entries = []
        for name in sorted(group.list_commands(None)):
            cmd = group.get_command(None, name)
            if cmd and not cmd.hidden:
                desc = cmd.get_short_help_str(limit=60).replace("'", "'\\''")
                entries.append(f"'{name}:{desc}'")
        return entries

    def fmt_options(cmd):
        entries = []
        for param in cmd.params:
            if isinstance(param, click.Option) and not param.hidden:
                for decl in param.opts:
                    if decl.startswith("--"):
                        desc = (param.help or "").replace("'", "'\\''")
                        entries.append(f"'{decl}[{desc}]'")
        return entries

    def has_packages_arg(cmd):
        return any(isinstance(p, click.Argument) and p.name == "packages" for p in cmd.params)

    o = []
    w = o.append

    w("#compdef innate in8")
    w("# Auto-generated — do not edit.")
    w("# Regenerate: innate completions > scripts/completions/_innate")
    w("")
    w("_innate_packages() {")
    w("  local -a pkgs")
    w('  local src_dir="${INNATE_OS_ROOT:-$HOME/innate-os}/ros2_ws/src"')
    w('  if [[ -d "$src_dir" ]]; then')
    w("    pkgs=( ${(f)\"$(find \"$src_dir\" -name package.xml -exec dirname {} \\; 2>/dev/null | xargs -I{} basename {})\"} )")
    w("    _describe 'ROS2 package' pkgs")
    w("  fi")
    w("}")
    w("")
    w("_innate() {")
    w("  local -a commands=(")
    for e in fmt_commands(cli):
        w(f"    {e}")
    w("  )")
    w("")
    w("  _arguments -C \\")
    w("    '1:command:->cmd' \\")
    w("    '*::arg:->args'")
    w("")
    w("  case $state in")
    w("    cmd)")
    w("      _describe 'innate command' commands")
    w("      ;;")
    w("    args)")
    w("      case $words[1] in")

    for name in sorted(cli.list_commands(None)):
        cmd = cli.get_command(None, name)
        if not cmd or cmd.hidden:
            continue

        if isinstance(cmd, click.Group):
            w(f"        {name})")
            w("          _arguments -C \\")
            w("            '1:action:->sub' \\")
            w("            '*::arg:->sub_args'")
            w("          case $state in")
            w("            sub)")
            w("              local -a actions=(")
            for e in fmt_commands(cmd):
                w(f"                {e}")
            w("              )")
            w(f"              _describe '{name} action' actions")
            w("              ;;")

            subs_with_opts = {}
            for sub_name in sorted(cmd.list_commands(None)):
                sub_cmd = cmd.get_command(None, sub_name)
                if sub_cmd and not sub_cmd.hidden:
                    opts = fmt_options(sub_cmd)
                    if opts:
                        subs_with_opts[sub_name] = opts

            if subs_with_opts:
                w("            sub_args)")
                w("              case $words[1] in")
                for sub_name, opts in sorted(subs_with_opts.items()):
                    w(f"                {sub_name})")
                    w("                  _arguments \\")
                    for i, opt_s in enumerate(opts):
                        trail = " \\" if i < len(opts) - 1 else ""
                        w(f"                    {opt_s}{trail}")
                    w("                  ;;")
                w("              esac")
                w("              ;;")

            w("          esac")
            w("          ;;")
        elif has_packages_arg(cmd):
            w(f"        {name})")
            w("          _innate_packages")
            w("          ;;")
        else:
            opts = fmt_options(cmd)
            if opts:
                w(f"        {name})")
                w("          _arguments \\")
                for i, opt_s in enumerate(opts):
                    trail = " \\" if i < len(opts) - 1 else ""
                    w(f"            {opt_s}{trail}")
                w("          ;;")

    w("      esac")
    w("      ;;")
    w("  esac")
    w("}")
    w("")
    w('_innate "$@"')

    return "\n".join(o) + "\n"


@cli.command("completions", hidden=True)
def completions():
    """Generate static zsh completions to stdout."""
    click.echo(_zsh_completions(), nl=False)


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main():
    cli()


if __name__ == "__main__":
    main()
