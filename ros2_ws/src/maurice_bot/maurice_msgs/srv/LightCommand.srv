# Constants for LED Modes
uint8 OFF=0
uint8 SOLID=1
uint8 BLINK=2
uint8 RING=3

# Request
uint8 mode       # LED Mode (0=Off, 1=Solid, 2=Blink, 3=Ring)
uint16 interval  # Time parameter for animations in milliseconds (1-10000 ms)
uint8 r          # Red intensity (0-255)
uint8 g          # Green intensity (0-255)
uint8 b          # Blue intensity (0-255)

---
# Response
bool success     # Whether the command was executed successfully
string message   # Status message
