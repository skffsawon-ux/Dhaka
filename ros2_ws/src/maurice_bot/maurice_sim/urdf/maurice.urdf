<robot name="maurice_bot">
  <!-- World link -->
  <link name="world" />

  <!-- Base Link -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.89"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/base.STL" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/base.STL" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Fixed joint from world to base_link -->
  <joint name="base_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- Joint 1: Connects base_link to link1 -->
  <joint name="joint1" type="revolute">
    <!-- Absolute offset from base_link -->
    <origin xyz="0.0845 -0.0597 0.0583" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="1.0" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- Link 1 -->
  <link name="link1">
    <!-- The link frame is defined at joint1 so we set origins to 0 -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.065"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link1.STL" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link1.STL" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 2: Connects link1 to link2 -->
  <joint name="joint2" type="revolute">
    <!-- Relative offset: 0.01825 m in z -->
    <origin xyz="0 0 0.01825" rpy="0 0 0"/>
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 1 0"/>
    <limit effort="1.5" velocity="1.0" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- Link 2 -->
  <link name="link2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.080"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link2.STL" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link2.STL" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 3: Connects link2 to link3 -->
  <joint name="joint3" type="revolute">
    <!-- Relative offset: (0.034, 0, 0.11825) -->
    <origin xyz="0.034 0 0.11825" rpy="0 0 0"/>
    <parent link="link2"/>
    <child link="link3"/>
    <axis xyz="0 1 0"/>
    <limit effort="1.5" velocity="1.0" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- Link 3 -->
  <link name="link3">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.055"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link3.STL" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link3.STL" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 4: Connects link3 to link4 -->
  <joint name="joint4" type="revolute">
    <!-- Relative offset: (0.13609, 0, 0.00025) -->
    <origin xyz="0.13609 0 0.00025" rpy="0 0 0"/>
    <parent link="link3"/>
    <child link="link4"/>
    <axis xyz="0 1 0"/>
    <limit effort="0.6" velocity="1.0" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- Link 4 -->
  <link name="link4">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.022"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link4.STL" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link4.STL" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 5: Connects link4 to link5 -->
  <joint name="joint5" type="revolute">
    <!-- Relative offset: (0.045, 0.002, 0) -->
    <origin xyz="0.045 0.002 0" rpy="0 0 0"/>
    <parent link="link4"/>
    <child link="link5"/>
    <axis xyz="1 0 0"/>
    <limit effort="0.6" velocity="1.0" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- Link 5 -->
  <link name="link5">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link5.STL" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link5.STL" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 6: Connects link5 to link6 -->
  <joint name="joint6" type="revolute">
    <!-- Relative offset: (0.059, -0.0055, 0) as per the table -->
    <origin xyz="0.059 -0.0055 0" rpy="0 0 0"/>
    <parent link="link5"/>
    <child link="link6"/>
    <axis xyz="0 0 1"/>
    <limit effort="0.6" velocity="1.0" lower="-3.14" upper="3.14"/>
  </joint>

  <!-- Link 6 -->
  <link name="link6">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.012"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link6.STL" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://maurice_sim/meshes/link6.STL" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
</robot>
