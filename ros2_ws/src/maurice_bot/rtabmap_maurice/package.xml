<?xml version="1.0"?>
<package format="3">
  <name>rtabmap_maurice</name>
  <version>0.1.0</version>
  <description>RTAB-Map + simulation bringup for Maurice robot</description>

  <maintainer email="you@example.com">Your Name</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>ament_cmake_python</buildtool_depend>

  <!-- We need rtabmap_slam, rtabmap_viz, rtabmap_util, etc. for these nodes -->
  <depend>rclpy</depend>
  <depend>rtabmap_slam</depend>
  <depend>rtabmap_util</depend>
  <depend>rtabmap_viz</depend>

  <export>
    <build_type>ament_python</build_type>
  </export>
</package>
