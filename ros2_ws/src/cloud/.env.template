# Robot client config (copy to .env, never commit .env)
#
# The .env walker in each node walks up from cwd looking for the
# first .env file, so placing .env here covers all client nodes
# when launched from the clients/ workspace.

# ── Required ───────────────────────────────────────────────────────
INNATE_SERVICE_KEY=

# ── Server URLs ────────────────────────────────────────────────────
# Local dev (docker compose up from repo root):
INNATE_AUTH_URL=http://localhost:8081
TRAINING_SERVER_URL=http://localhost:8082
INNATE_PROXY_URL=http://localhost:8083
#
# Production (defaults if unset):
# INNATE_AUTH_URL=https://auth-v1.innate.bot
# TRAINING_SERVER_URL=https://training-v1.innate.bot
