#
# Dockerfile.test - Test image for CI on non-Jetson platforms
# Skips Jetson-specific packages (nvidia-*, cuda-*, etc.)
#

FROM ros:humble-ros-base

ENV DEBIAN_FRONTEND=noninteractive
ENV ROS_DISTRO=humble
ENV INNATE_OS_ROOT=/root/innate-os

# Install minimal prerequisites first (needed for add-apt-repository)
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    curl \
    gnupg \
    lsb-release \
    && rm -rf /var/lib/apt/lists/*

# Add universe repository (for gstreamer, pygame, libhdf5-dev, etc.)
RUN add-apt-repository universe

# Install remaining prerequisites
RUN apt-get update && apt-get install -y --no-install-recommends \
    locales \
    iproute2 \
    iputils-ping \
    libcairo2-dev \
    python3-pip \
    libhdf5-dev \
    ros-humble-kdl-parser \
    && rm -rf /var/lib/apt/lists/*

# Setup locale
RUN locale-gen en_US en_US.UTF-8 && \
    update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8
ENV LANG=en_US.UTF-8

# Add Innate packages repository (for ros-humble-innate-rws, etc.)
RUN curl -fsSL https://innate-inc.github.io/innate-packages/pubkey.gpg | \
    gpg --dearmor -o /usr/share/keyrings/innate-archive-keyring.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/innate-archive-keyring.gpg] https://innate-inc.github.io/innate-packages/ $(lsb_release -cs) main" | \
    tee /etc/apt/sources.list.d/innate.list > /dev/null

# Copy apt dependencies file first (for better layer caching)
COPY ros2_ws/apt-dependencies.common.txt /tmp/apt-dependencies.txt

# Install apt dependencies from common list
RUN apt-get update && \
    grep -v '^#' /tmp/apt-dependencies.txt | grep -v '^$' | \
    xargs apt-get install -y && \
    rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies, skipping Jetson-specific packages
COPY ros2_ws/pip-requirements.txt /tmp/pip-requirements.txt
RUN pip3 install --no-cache-dir meson ninja && \
    grep -v 'pypi.jetson-ai-lab.io' /tmp/pip-requirements.txt | \
    grep -v -E '^cupy' | \
    grep -v -E '^pynput' | \
    grep -v -E '^bluezero' | \
    pip3 install --no-cache-dir -r /dev/stdin

# Initialize rosdep
RUN rosdep init || true && rosdep update

# Set up workspace directory
WORKDIR /root/innate-os

# Copy workspace source
COPY ros2_ws /root/innate-os/ros2_ws

# Copy DDS configuration
COPY dds /root/innate-os/dds

# Copy additional directories needed at runtime
COPY config /root/innate-os/config
COPY skills /root/innate-os/skills
COPY agents /root/innate-os/agents

# Import external dependencies using vcs
RUN cd /root/innate-os/ros2_ws/src && \
    if [ -f dependencies.repos ]; then \
        echo "Importing external dependencies via vcs..." && \
        vcs import --input dependencies.repos; \
    fi

# Install ROS dependencies and build workspace, skipping Jetson-dependent packages
WORKDIR /root/innate-os/ros2_ws
RUN . /opt/ros/humble/setup.sh && \
    rosdep install --from-paths src --ignore-src -r -y || true && \
    colcon build --parallel-workers 2 --cmake-args -DCMAKE_BUILD_TYPE=Release \
        --packages-skip maurice_cam maurice_nav maurice_control

# Create entrypoint script with Zenoh configuration
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
# Source ROS2 base\n\
source /opt/ros/humble/setup.bash\n\
\n\
# Source workspace\n\
if [ -f /root/innate-os/ros2_ws/install/setup.bash ]; then\n\
    source /root/innate-os/ros2_ws/install/setup.bash\n\
fi\n\
\n\
# Set Zenoh RMW environment variables\n\
export RMW_IMPLEMENTATION=rmw_zenoh_cpp\n\
export ROS_DOMAIN_ID=0\n\
export ZENOH_ROUTER_CHECK_ATTEMPTS=0\n\
export ZENOH_SESSION_CONFIG_OVERRIDE="transport/shared_memory/enabled=true;transport/shared_memory/transport_optimization/pool_size=12582912;transport/link/tx/queue/congestion_control/drop/wait_before_drop=200000;transport/link/tx/queue/congestion_control/drop/max_wait_before_drop_fragments=300000"\n\
export ZENOH_CONFIG_OVERRIDE="$ZENOH_SESSION_CONFIG_OVERRIDE"\n\
export INNATE_OS_ROOT=/root/innate-os\n\
\n\
exec "$@"' > /entrypoint.sh && chmod +x /entrypoint.sh

WORKDIR /root/innate-os

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]

# Labels for image metadata
ARG VERSION=dev
ARG BUILD_DATE
ARG GIT_COMMIT
LABEL org.opencontainers.image.title="Innate OS Test" \
      org.opencontainers.image.description="ROS2-based robot operating system (test build)" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${GIT_COMMIT}" \
      org.opencontainers.image.source="https://github.com/innate-inc/innate-os"
