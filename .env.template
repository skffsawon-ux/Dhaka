# Environment variables template for Maurice robot
# Copy this file to .env and fill in your actual values
# The .env file is git-ignored for security

# Cartesia API key for text-to-speech functionality
# Get your API key from: https://cartesia.ai
CARTESIA_API_KEY=your_api_key_here
OPENAI_API_KEY=sk-proj-your-actual-key-here

# Add other sensitive environment variables here as needed
# Example:
# OPENAI_API_KEY=your_openai_key_here
# DATABASE_URL=your_database_url_here
