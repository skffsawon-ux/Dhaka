# Environment variables template for Maurice robot
# Copy this file to .env and fill in your actual values
# The .env file is git-ignored for security

# =============================================================================
# Innate Brain Connection
# =============================================================================
BRAIN_WEBSOCKET_URI=wss://brain.innate.bot
BRAIN_WEBSOCKET_URI_SIM=ws://host.docker.internal:8765
BRAIN_AUTH_TOKEN=your_auth_token_here

# =============================================================================
# Innate Services
# =============================================================================
INNATE_PROXY_URL=https://innate-service-proxy-3utn4fttaq-uc.a.run.app
# Will be one token for both brain and services
INNATE_SERVICE_KEY=your_service_key_here
TELEMETRY_URL=https://logs.innate.bot

# =============================================================================
# Text-to-Speech (Cartesia)
# =============================================================================
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02

